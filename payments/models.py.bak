from django.db import models
from django.db.models.signals import post_save
from django.dispatch import receiver
from tenants.models import Tenant


class Rent(models.Model):
    STATUS_CHOICES = (
        ('PAID', 'Paid'),
        ('UNPAID', 'Unpaid'),
        ('PARTIAL', 'Partial'),
    )

    tenant = models.ForeignKey(Tenant, on_delete=models.CASCADE)
    amount = models.DecimalField(max_digits=10, decimal_places=2)
    month = models.CharField(max_length=20)
    year = models.IntegerField()

    amount_paid = models.DecimalField(max_digits=10, decimal_places=2, default=0)
    balance = models.DecimalField(max_digits=10, decimal_places=2, default=0)

    status = models.CharField(max_length=10, choices=STATUS_CHOICES, default='UNPAID')
    date_created = models.DateTimeField(auto_now_add=True)

    def save(self, *args, **kwargs):
        self.balance = self.amount - self.amount_paid

        if self.balance <= 0:
            self.status = 'PAID'
        elif self.amount_paid > 0:
            self.status = 'PARTIAL'
        else:
            self.status = 'UNPAID'

        super().save(*args, **kwargs)

    def __str__(self):
        return f"{self.tenant} - {self.month} {self.year}"

    class Meta:
        unique_together = ('tenant', 'month', 'year')


class Payment(models.Model):
    PAYMENT_METHOD_CHOICES = (
        ('CASH', 'Cash'),
        ('MPESA', 'M-Pesa'),
        ('BANK', 'Bank'),
        ('OTHER', 'Other'),
    )

    rent = models.ForeignKey(Rent, on_delete=models.CASCADE, related_name='payments')
    amount = models.DecimalField(max_digits=10, decimal_places=2)
    payment_date = models.DateField()
    payment_method = models.CharField(max_length=20, choices=PAYMENT_METHOD_CHOICES, default='MPESA')
    transaction_code = models.CharField(max_length=100, blank=True, null=True, unique=True)
    phone_number = models.CharField(max_length=15, blank=True, null=True)
    notes = models.TextField(blank=True, null=True)
    verified = models.BooleanField(default=False)
    date_created = models.DateTimeField(auto_now_add=True)

    def save(self, *args, **kwargs):
        if self.payment_method == 'MPESA':
            self.verified = True
        super().save(*args, **kwargs)

    def __str__(self):
        return f"{self.rent.tenant.full_name} - {self.amount} on {self.payment_date}"


@receiver(post_save, sender=Payment)
def update_rent_on_payment(sender, instance, created, **kwargs):
    rent = instance.rent
    total_paid = sum(payment.amount for payment in rent.payments.all())
    rent.amount_paid = total_paid
    rent.save()
