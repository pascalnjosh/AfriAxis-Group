from django.contrib import admin, messages
from django.core.exceptions import ValidationError
from django.shortcuts import redirect, render
from django.urls import path

from .models import Rent, Payment
from tenants.models import Tenant


class PaymentInline(admin.TabularInline):
    model = Payment
    extra = 1


@admin.register(Payment)
class PaymentAdmin(admin.ModelAdmin):
    list_display = (
        'rent',
        'amount',
        'payment_date',
        'payment_method',
        'transaction_code',
        'verified',
    )
    list_filter = ('payment_method', 'payment_date', 'verified')
    search_fields = ('rent__tenant__full_name', 'transaction_code')

    def save_model(self, request, obj, form, change):
        if obj.payment_method == 'MPESA' and not obj.transaction_code:
            raise ValidationError("MPESA payments must have a transaction code.")
        super().save_model(request, obj, form, change)


@admin.register(Rent)
class RentAdmin(admin.ModelAdmin):
    inlines = [PaymentInline]

    list_display = (
        'tenant',
        'get_apartment',
        'month',
        'year',
        'amount',
        'amount_paid',
        'balance_display',
        'status',
    )

    list_filter = ('status', 'month', 'year', 'tenant__unit__apartment')
    search_fields = ('tenant__full_name',)

    def get_apartment(self, obj):
        if obj.tenant and obj.tenant.unit:
            return obj.tenant.unit.apartment
        return "No Unit"

    get_apartment.short_description = "Apartment"

    def balance_display(self, obj):
        if obj.balance > 0:
            return f"❌ Arrears: KES {obj.balance}"
        return "✅ Cleared"

    balance_display.short_description = "Balance"

    def changelist_view(self, request, extra_context=None):
        extra_context = extra_context or {}

        qs = self.get_queryset(request)

        extra_context["dashboard"] = {
            "total_expected": sum(r.amount for r in qs),
            "total_collected": sum(r.amount_paid for r in qs),
            "total_balance": sum(r.balance for r in qs),
            "paid_count": qs.filter(status='PAID').count(),
            "unpaid_count": qs.filter(status='UNPAID').count(),
            "partial_count": qs.filter(status='PARTIAL').count(),
            "defaulters_count": qs.filter(balance__gt=0).count(),
        }
        extra_context["show_generate_rent_button"] = True

        return super().changelist_view(request, extra_context=extra_context)

    def get_urls(self):
        urls = super().get_urls()
        custom_urls = [
            path(
                "generate-rent/",
                self.admin_site.admin_view(self.generate_rent_view),
                name="payments_rent_generate_rent",
            ),
        ]
        return custom_urls + urls

    def generate_rent_view(self, request):
        if request.method == "POST":
            month = request.POST.get("month")
            year = int(request.POST.get("year"))

            tenants = Tenant.objects.filter(is_active=True)

            created_count = 0
            skipped_count = 0

            for tenant in tenants:
                if not tenant.unit:
                    skipped_count += 1
                    continue

                _, created = Rent.objects.get_or_create(
                    tenant=tenant,
                    month=month,
                    year=year,
                    defaults={
                        "amount": tenant.unit.rent_amount,
                        "amount_paid": 0,
                        "balance": tenant.unit.rent_amount,
                        "status": "UNPAID",
                    },
                )

                if created:
                    created_count += 1
                else:
                    skipped_count += 1

            self.message_user(
                request,
                f"Rent generated. Created: {created_count}, Skipped: {skipped_count}",
                level=messages.SUCCESS,
            )
            return redirect("../")

        context = {
            **self.admin_site.each_context(request),
            "title": "Generate Monthly Rent",
        }
        return render(request, "admin/payments/rent/generate_rent.html", context)
