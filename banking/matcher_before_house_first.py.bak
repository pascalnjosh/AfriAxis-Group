import re
from decimal import Decimal
from difflib import SequenceMatcher

from rentals.models import House, Rent, Tenant


APARTMENT_PREFIXES = {
    "B": "BLUEVALLEY",
    "E": "EASTWARD",
    "G": "GULF",
    "M": "MUTHAIGA",
    "O": "OASIS BUSINESS CENTER",
}


def normalize_phone(value):
    digits = re.sub(r"\D", "", str(value or ""))

    if digits.startswith("0") and len(digits) == 10:
        digits = "254" + digits[1:]
    elif len(digits) == 9:
        digits = "254" + digits

    return digits


def normalize_text(value):
    text = str(value or "").upper()
    text = re.sub(r"[^A-Z0-9\s]", " ", text)
    return re.sub(r"\s+", " ", text).strip()


def extract_phone_numbers(text):
    return set(re.findall(r"\b254\d{9}\b", text))


def extract_house_number(text):
    """
    Examples supported:
    '47'
    'HOUSE 47'
    'E4 WAWERU'
    '039 PETER'
    """
    cleaned = re.sub(r"\b254\d{9}\b", " ", text)
    cleaned = cleaned.replace("501273", " ")

    house_match = re.search(r"\bHOUSE\s*0*(\d{1,3})\b", cleaned)
    if house_match:
        return str(int(house_match.group(1)))

    prefix_match = re.search(r"\b([BEGMO])\s*0*(\d{1,3})\b", cleaned)
    if prefix_match:
        return str(int(prefix_match.group(2)))

    numbers = re.findall(r"\b0*(\d{1,3})\b", cleaned)

    if numbers:
        return str(int(numbers[-1]))

    return None


def extract_apartment_prefix(text):
    match = re.search(r"\b([BEGMO])\s*0*\d{1,3}\b", text)

    if match:
        return match.group(1)

    return None


def house_number_only(value):
    match = re.search(r"\d+", str(value or ""))

    if match:
        return str(int(match.group()))

    return ""


def get_tenant_house(tenant):
    house = (
        House.objects.filter(
            tenant=tenant,
            occupied=True,
        )
        .select_related("apartment")
        .first()
    )

    if house:
        return house

    house = (
        House.objects.filter(tenant=tenant)
        .select_related("apartment")
        .first()
    )

    if house:
        return house

    rent = (
        Rent.objects.filter(tenant=tenant)
        .select_related("house", "house__apartment")
        .order_by("-billing_month", "-id")
        .first()
    )

    return rent.house if rent else None


def exact_name_match(tenant_name, text):
    name = normalize_text(tenant_name)

    if not name:
        return False

    # Word boundaries prevent IAN from matching SIDIAN.
    pattern = rf"(?<![A-Z0-9]){re.escape(name)}(?![A-Z0-9])"
    return re.search(pattern, text) is not None


def fuzzy_name_score(tenant_name, text):
    name = normalize_text(tenant_name)

    if not name or len(name) < 4:
        return 0

    words = text.split()
    best = 0

    for word in words:
        if len(word) < 4:
            continue

        ratio = SequenceMatcher(None, name, word).ratio()
        best = max(best, ratio)

    if best >= 0.93:
        return 30

    if best >= 0.86:
        return 15

    return 0


def score_tenant(transaction, tenant, text):
    score = 0
    reasons = []

    phones = extract_phone_numbers(text)
    tenant_phone = normalize_phone(tenant.phone)

    if tenant_phone and tenant_phone in phones:
        score += 70
        reasons.append("phone")

    if exact_name_match(tenant.name, text):
        score += 50
        reasons.append("name")
    else:
        fuzzy_score = fuzzy_name_score(tenant.name, text)

        if fuzzy_score:
            score += fuzzy_score
            reasons.append("similar name")

    house = get_tenant_house(tenant)
    statement_house = extract_house_number(text)

    if house and statement_house:
        database_house = house_number_only(house.house_number)

        if database_house == statement_house:
            score += 40
            reasons.append("house")

    prefix = extract_apartment_prefix(text)

    if house and house.apartment and prefix:
        expected_apartment = APARTMENT_PREFIXES.get(prefix, "")
        apartment_name = normalize_text(house.apartment.name)

        if expected_apartment and apartment_name == expected_apartment:
            score += 25
            reasons.append("apartment")
        else:
            score -= 30
            reasons.append("apartment conflict")

    if house and transaction.money_in:
        payment_amount = Decimal(transaction.money_in)
        rent_amount = Decimal(house.rent_amount)

        if payment_amount == rent_amount:
            score += 20
            reasons.append("exact rent amount")
        elif payment_amount > 0 and payment_amount < rent_amount:
            score += 8
            reasons.append("partial rent amount")

    return score, reasons, house


def auto_match(transaction):
    text = normalize_text(transaction.description)

    transaction.matched_tenant = None
    transaction.matched_house = None
    transaction.auto_matched = False
    transaction.confidence = 0

    if "ACCOUNT STATEMENT CHARGE" in text or "EXCISE DUTY" in text:
        transaction.transaction_type = "money_out"
        transaction.suggested_category = "expense"
        transaction.match_notes = "Bank charge or excise duty"
        transaction.save()
        return transaction

    if transaction.money_in and transaction.money_in > 0:
        transaction.transaction_type = "money_in"
        transaction.suggested_category = "rent"
    elif transaction.money_out and transaction.money_out > 0:
        transaction.transaction_type = "money_out"
        transaction.suggested_category = "expense"
    else:
        transaction.transaction_type = "unknown"
        transaction.suggested_category = "unknown"

    results = []

    for tenant in Tenant.objects.exclude(name=""):
        score, reasons, house = score_tenant(
            transaction,
            tenant,
            text,
        )

        if score > 0:
            results.append(
                {
                    "tenant": tenant,
                    "house": house,
                    "score": score,
                    "reasons": reasons,
                }
            )

    results.sort(key=lambda item: item["score"], reverse=True)

    if not results:
        transaction.match_notes = "No suitable tenant match"
        transaction.save()
        return transaction

    best = results[0]
    second_score = results[1]["score"] if len(results) > 1 else 0
    score_gap = best["score"] - second_score

    # Prevent ambiguous matches.
    if best["score"] < 50 or score_gap < 15:
        transaction.match_notes = (
            f"Pending review: ambiguous match. "
            f"Best score {best['score']}, gap {score_gap}."
        )
        transaction.save()
        return transaction

    confidence = min(best["score"], 99)

    transaction.matched_tenant = best["tenant"]
    transaction.matched_house = best["house"]
    transaction.confidence = confidence
    transaction.auto_matched = confidence >= 90
    transaction.match_notes = (
        f"Matched using {', '.join(best['reasons'])}. "
        f"Score: {best['score']}."
    )
    transaction.save()

    return transaction