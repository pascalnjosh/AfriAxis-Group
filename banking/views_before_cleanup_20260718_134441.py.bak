        Payment.objects.create(
            rental_rent=rent,
            amount=transaction.money_in,
            phone_number="",
            account_reference="BANK",
            transaction_desc=transaction.description,
            payment_method="BANK",
            status="SUCCESS",
        )

    transaction.match_status = "approved"
    transaction.save()

    messages.success(request, "Transaction approved.")
    return redirect("bank_reconciliation")

@login_required
def undo_transaction(request, transaction_id):
    from payments.models import Payment

    transaction = get_object_or_404(BankTransaction, id=transaction_id)

    if transaction.match_status == "approved":
        payments = Payment.objects.filter(
            amount=transaction.money_in,
            payment_method="BANK",
            transaction_desc=transaction.description,
        )

        for payment in payments:
            rent = payment.rental_rent

            if rent:
                rent.amount_paid = rent.amount_paid - transaction.money_in

                if rent.amount_paid < 0:
                    rent.amount_paid = 0

                rent.balance = rent.amount - rent.amount_paid
                rent.paid = rent.balance <= 0
                rent.save()

        deleted_count = payments.count()
        payments.delete()

    transaction.match_status = "pending"
    transaction.save()

    messages.success(request, "Transaction returned to pending.")
    return redirect("bank_reconciliation")

@login_required
def approve_all_high_confidence(request):
    from rentals.models import Rent
    from payments.models import Payment

    transactions = BankTransaction.objects.filter(
        match_status="pending",
        auto_matched=True,
        confidence__gte=95,
        money_in__gt=0,
        matched_tenant__isnull=False,
    )

    count = 0

    for transaction in transactions:
        rent = (
            Rent.objects.filter(
                tenant=transaction.matched_tenant,
                paid=False,
            )
            .order_by("due_date")
            .first()
        )

        if rent:
            rent.amount_paid = rent.amount_paid + transaction.money_in
            rent.balance = rent.amount - rent.amount_paid
            rent.paid = rent.balance <= 0
            rent.save()

        Payment.objects.create(
            rental_rent=rent,
            amount=transaction.money_in,
            phone_number="",
            account_reference="BANK",
            transaction_desc=transaction.description,
            payment_method="BANK",
            status="SUCCESS",
        )

    transaction.match_status = "approved"
    transaction.save()

    messages.success(request, "Transaction approved.")
    return redirect("bank_reconciliation")

@login_required
def undo_transaction(request, transaction_id):
    from payments.models import Payment

    transaction = get_object_or_404(BankTransaction, id=transaction_id)

    if transaction.match_status != "approved":
        messages.warning(request, "Transaction is not approved.")
        return redirect("bank_reconciliation")

    payments = Payment.objects.filter(
        amount=transaction.money_in,
        payment_method="BANK",
        transaction_desc=transaction.description,
    )

    for payment in payments:
        rent = payment.rental_rent

        if rent:
            rent.amount_paid -= transaction.money_in
            rent.save()

        payment.delete()

    transaction.match_status = "pending"
    transaction.save()

    messages.success(request, "Transaction has been reversed.")
    return redirect("bank_reconciliation") 

@login_required
def reject_transaction(request, transaction_id):
    transaction = get_object_or_404(BankTransaction, id=transaction_id)

    transaction.match_status = "rejected"
    transaction.save()

    messages.success(request, "Transaction rejected.")
    return redirect("bank_reconciliation")
